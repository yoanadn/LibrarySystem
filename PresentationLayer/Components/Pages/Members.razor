@page "/members"
@rendermode InteractiveServer
@using BusinessLayer
@using DataLayer
@inject LibraryContext context

<div class="module-page">
    <h2 class="mb-4">Members</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header text-white module-header">Create Member</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label">Name</label>
                    <input class="form-control" @bind="name" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control" @bind="email" type="email" />
                </div>
                <div class="col-12">
                    <button class="btn btn-primary px-4" @onclick="AddMember">Add Member</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light fw-semibold">Members List</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th class="text-end">Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in members)
                        {
                            <tr>
                                <td>@m.Name</td>
                                <td>@m.Email</td>
                                <td class="text-end">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteMember(m.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Member> members = new();

    private string name = string.Empty;
    private string email = string.Empty;

    protected override void OnInitialized()
    {
        LoadMembers();
    }

    private void LoadMembers()
    {
        members = context.Members
            .OrderBy(m => m.Name)
            .ToList();
    }

    private void AddMember()
    {
        if (string.IsNullOrWhiteSpace(name) || string.IsNullOrWhiteSpace(email))
            return;

        Member member = new()
        {
            Name = name.Trim(),
            Email = email.Trim()
        };

        context.Members.Add(member);
        context.SaveChanges();

        name = string.Empty;
        email = string.Empty;

        LoadMembers();
    }

    private void DeleteMember(int id)
    {
        var member = context.Members.Find(id);

        if (member != null)
        {
            context.Members.Remove(member);
            context.SaveChanges();
        }

        LoadMembers();
    }
}
