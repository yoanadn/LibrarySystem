@page "/categories"
@rendermode InteractiveServer
@using BusinessLayer
@using DataLayer
@inject LibraryContext context

<div class="module-page">
    <h2 class="mb-4">Categories</h2>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header text-white module-header">Create Category</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-md-8">
                    <label class="form-label">Category name</label>
                    <input class="form-control" @bind="name" placeholder="Enter category" />
                </div>
                <div class="col-12">
                    <button class="btn btn-primary px-4" @onclick="AddCategory">Add Category</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-light fw-semibold">Categories List</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th class="text-end">Delete</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in categories)
                        {
                            <tr>
                                <td><span class="badge text-bg-secondary">@c.Name</span></td>
                                <td class="text-end">
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteCategory(c.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Category> categories = new();
    private string name = string.Empty;

    protected override void OnInitialized()
    {
        LoadCategories();
    }

    private void LoadCategories()
    {
        categories = context.Categories
            .OrderBy(c => c.Name)
            .ToList();
    }

    private void AddCategory()
    {
        if (string.IsNullOrWhiteSpace(name))
            return;

        Category category = new()
        {
            Name = name.Trim()
        };

        context.Categories.Add(category);
        context.SaveChanges();

        name = string.Empty;

        LoadCategories();
    }

    private void DeleteCategory(int id)
    {
        var category = context.Categories.Find(id);

        if (category != null)
        {
            context.Categories.Remove(category);
            context.SaveChanges();
        }

        LoadCategories();
    }
}
