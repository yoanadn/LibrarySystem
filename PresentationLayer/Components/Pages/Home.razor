@page "/"
@using BusinessLayer
@using DataLayer
@using Microsoft.EntityFrameworkCore
@inject LibraryContext context

<div class="home-page">
    <section class="quick-actions mb-4">
        <a class="btn quick-btn" href="/books">
            <i class="bi bi-journal-plus"></i>
            Add Book
        </a>
        <a class="btn quick-btn" href="/authors">
            <i class="bi bi-person-plus"></i>
            Add Author
        </a>
        <a class="btn quick-btn" href="/members">
            <i class="bi bi-people-fill"></i>
            Add Member
        </a>
    </section>

    <section class="dashboard-hero mb-4">
        <div class="hero-content">
            <div class="hero-title-wrap">
                <span class="hero-icon"><i class="bi bi-journal-bookmark-fill"></i></span>
                <h1 class="hero-title">Library System</h1>
            </div>
            <p class="hero-description mb-0">
                Modern library dashboard for books, people and circulation.
            </p>
        </div>
        <div class="hero-illustration" aria-hidden="true">
            <i class="bi bi-stack"></i>
        </div>
    </section>

    <section class="row g-3 mb-4 stats-row">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dash-stat-card stat-books">
                <div class="stat-icon-wrap"><i class="bi bi-book"></i></div>
                <div class="stat-label">Books</div>
                <div class="stat-value">@booksCount</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dash-stat-card stat-authors">
                <div class="stat-icon-wrap"><i class="bi bi-person"></i></div>
                <div class="stat-label">Authors</div>
                <div class="stat-value">@authorsCount</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dash-stat-card stat-members">
                <div class="stat-icon-wrap"><i class="bi bi-people"></i></div>
                <div class="stat-label">Members</div>
                <div class="stat-value">@membersCount</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="dash-stat-card stat-loans">
                <div class="stat-icon-wrap"><i class="bi bi-arrow-left-right"></i></div>
                <div class="stat-label">Active Loans</div>
                <div class="stat-value">@loansCount</div>
            </div>
        </div>
    </section>

    <section class="latest-books-panel">
        <div class="panel-head">
            <h3 class="mb-0">Latest Books</h3>
            <span class="panel-sub">@latestBooks.Count items</span>
        </div>
        <div class="panel-body">
            @if (latestBooks.Any())
            {
                <div class="row g-3">
                    @foreach (var book in latestBooks)
                    {
                        <div class="col-12 col-lg-6">
                            <div class="book-dash-card">
                                <div>
                                    <h4 class="book-title">@book.Title</h4>
                                    <p class="book-author mb-2">@book.Author?.Name</p>
                                    <div class="book-categories">
                                        @if (book.BookCategories != null && book.BookCategories.Any())
                                        {
                                            @foreach (var category in book.BookCategories.Take(3))
                                            {
                                                <span class="badge rounded-pill text-bg-secondary me-1 mb-1">@category.Category?.Name</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill text-bg-secondary">Uncategorized</span>
                                        }
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <a class="btn btn-outline-dark btn-sm rounded-pill px-3" href="/loans">
                                        <i class="bi bi-arrow-right-circle me-1"></i>
                                        Borrow
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-journal-x"></i>
                    <p class="mb-0">No books yet.</p>
                </div>
            }
        </div>
    </section>
</div>

@code {
    private List<Book> latestBooks = new();
    private int booksCount;
    private int authorsCount;
    private int membersCount;
    private int loansCount;

    protected override void OnInitialized()
    {
        booksCount = context.Books.Count();
        authorsCount = context.Authors.Count();
        membersCount = context.Members.Count();
        loansCount = context.Loans.Count();

        latestBooks = context.Books
            .Include(b => b.Author)
            .Include(b => b.BookCategories)
            .ThenInclude(bc => bc.Category)
            .OrderByDescending(b => b.Id)
            .Take(5)
            .ToList();
    }
}
